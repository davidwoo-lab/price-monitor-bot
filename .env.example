# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=price_monitor
DB_USERNAME=root
DB_PASSWORD=

# Slack (set SLACK_ENABLED=true to activate)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram (set TELEGRAM_ENABLED=true to activate)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# KakaoTalk (set KAKAO_ENABLED=true to activate)
KAKAO_ENABLED=false
KAKAO_ACCESS_TOKEN=YOUR_ACCESS_TOKEN

# Scheduler cron expression (default: every hour)
SCHEDULER_CRON=0 0 * * * *

# Distributed lock (ShedLock) durations, ISO-8601 (multi-instance safety)
SCHEDULER_LOCK_AT_MOST_FOR=PT30M
SCHEDULER_LOCK_AT_LEAST_FOR=PT1M

# Delay between product crawl requests in milliseconds
CRAWLER_REQUEST_DELAY_MS=2000

# Crawl retry on transient failures
CRAWLER_MAX_RETRY_COUNT=2
CRAWLER_RETRY_DELAY_MS=1000

# Notification cooldown in minutes (default: 60)
ALERT_COOLDOWN_MINUTES=60

# Abnormal price-change threshold (e.g. 0.70 = hold alert on >70% deviation)
ALERT_PRICE_CHANGE_THRESHOLD=0.70

# Daily price summary job + raw history retention
SUMMARY_CRON=0 0 4 * * *
SUMMARY_RETENTION_DAYS=30
